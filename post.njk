<!DOCTYPE html>
<html lang="hi-IN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | High Tech Pest Control Lucknow</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ title }} — High Tech Pest Control Lucknow. Deemak, cockroach aur pest control ke baare mein jankari.{% endif %}">
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <meta name="robots" content="index, follow, max-image-preview:large">
  <meta name="theme-color" content="#0F2E1A">
  <link rel="canonical" href="https://hightechpestcontrol.co.in/blog/{{ page.fileSlug }}/">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/favicon.svg">
  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ title }}{% endif %}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="https://hightechpestcontrol.co.in/blog/{{ page.fileSlug }}/">
  <meta property="og:image" content="{% if thumbnail %}https://hightechpestcontrol.co.in{{ thumbnail }}{% else %}https://hightechpestcontrol.co.in/og-image.jpg{% endif %}">
  <meta property="og:site_name" content="High Tech Pest Control">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="{% if thumbnail %}https://hightechpestcontrol.co.in{{ thumbnail }}{% else %}https://hightechpestcontrol.co.in/og-image.jpg{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Noto+Sans+Devanagari:wght@400;600&display=swap" rel="stylesheet">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "author": {"@type": "Person", "name": "Mohd Kaleem", "url": "https://hightechpestcontrol.co.in/"},
    "publisher": {"@type": "Organization", "name": "High Tech Pest Control", "url": "https://hightechpestcontrol.co.in/"},
    "datePublished": "{{ date | isoDate }}",
    "url": "https://hightechpestcontrol.co.in/blog/{{ page.fileSlug }}/",
    "inLanguage": "hi-IN"
  }
  </script>

  <style>
    :root{--green-900:#0F2E1A;--green-800:#1A4428;--green-600:#2D7044;--green-100:#E8F5ED;--saffron:#E8820C;--ivory:#FAFAF7;--cream:#F5F3EE;--text-main:#2A2A27;--text-muted:#6B6860;--font-display:'Playfair Display',Georgia,serif;--font-body:'DM Sans','Noto Sans Devanagari',sans-serif}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--font-body);background:var(--ivory);color:var(--text-main);font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased}
    .nav{background:var(--green-900);padding:14px 20px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:100}
    .nav a{color:rgba(255,255,255,.8);text-decoration:none;font-size:.9rem}
    .nav-logo{font-family:var(--font-display);color:#fff;font-weight:800;font-size:1.1rem}
    .nav-logo span{color:var(--saffron)}
    .blog-header{background:linear-gradient(135deg,var(--green-900),var(--green-600));padding:60px 20px;text-align:center}
    .blog-tag{display:inline-block;background:var(--saffron);color:#fff;font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 14px;border-radius:100px;margin-bottom:16px}
    .blog-header h1{font-family:var(--font-display);font-size:clamp(1.6rem,4vw,2.4rem);color:#fff;max-width:700px;margin:0 auto 16px}
    .blog-meta{color:rgba(255,255,255,.6);font-size:.85rem}
    .header-img{width:100%;max-height:400px;object-fit:cover;display:block}
    .blog-body{padding:48px 20px 60px;max-width:760px;margin:0 auto}
    .blog-body h2{font-family:var(--font-display);font-size:1.5rem;color:var(--green-900);margin:36px 0 14px}
    .blog-body h3{font-size:1.15rem;font-weight:700;color:var(--green-800);margin:28px 0 10px}
    .blog-body p{margin-bottom:18px;color:var(--text-main)}
    .blog-body ul,.blog-body ol{margin:16px 0 24px 24px}
    .blog-body li{margin-bottom:8px}
    .blog-body img{max-width:100%;border-radius:12px;margin:20px 0}
    .blog-body a{color:var(--saffron);font-weight:600}
    .blog-body strong{color:var(--green-900)}
    .blog-body blockquote{border-left:4px solid var(--saffron);background:var(--cream);padding:16px 20px;border-radius:0 12px 12px 0;margin:20px 0;font-style:italic}
    .author-box{max-width:760px;margin:0 auto;padding:0 20px}
    .author-card{background:#fff;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(15,46,26,.07);display:flex;gap:18px;align-items:center;border-left:4px solid var(--saffron)}
    .author-avatar{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--saffron),#c4690a);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:1.6rem;font-weight:800;color:#fff;flex-shrink:0}
    .cta-box{background:var(--green-900);border-radius:16px;padding:32px;text-align:center;margin:48px auto;max-width:760px}
    .cta-box h3{font-family:var(--font-display);color:#fff;font-size:1.4rem;margin-bottom:10px}
    .cta-box p{color:rgba(255,255,255,.7);margin-bottom:20px;font-size:.95rem}
    .cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .btn-wa{display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;padding:13px 24px;border-radius:10px;font-weight:600;text-decoration:none;font-size:.9rem}
    .btn-call{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.1);color:#fff;padding:13px 24px;border-radius:10px;font-weight:600;text-decoration:none;font-size:.9rem}
    .footer{background:var(--green-900);color:rgba(255,255,255,.6);text-align:center;padding:24px;font-size:.85rem;margin-top:40px}
    .footer a{color:var(--saffron);text-decoration:none}
    .wa-float{position:fixed;bottom:24px;right:24px;background:#25D366;color:#fff;width:58px;height:58px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.5);z-index:999}
  </style>
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">High<span>Tech</span> Pest Control</a>
  <a href="tel:+916392026107">📞 6392026107</a>
</nav>

<div class="blog-header">
  <span class="blog-tag">{{ category }}</span>
  <h1>{{ title }}</h1>
  <p class="blog-meta">✍️ Mohd Kaleem &nbsp;·&nbsp; 📅 {{ date | readableDate }} &nbsp;·&nbsp; ⏱️ {% if readtime %}{{ readtime }}{% else %}4{% endif %} min read</p>
</div>

{% if thumbnail %}<img src="{{ thumbnail }}" alt="{{ title }}" class="header-img">{% endif %}

<article class="blog-body">
  {{ content | safe }}
</article>

<div class="author-box">
  <div class="author-card">
    <div class="author-avatar">MK</div>
    <div>
      <div style="font-weight:700;color:#0F2E1A;font-size:1.05rem">Mohd Kaleem</div>
      <div style="color:#E8820C;font-size:.85rem;font-weight:600;margin-bottom:6px">Founder, High Tech Pest Control · 7+ Years Experience</div>
      <p style="font-size:.88rem;color:#6B6860;margin:0;line-height:1.6">2017 se Lucknow mein pest control expert. 2000+ gharon ka deemak aur keedo se ilaj kiya hai.</p>
    </div>
  </div>
</div>

<div class="cta-box">
  <h3>Pest Control Service Chahiye?</h3>
  <p>Free inspection book karein — same day response. Koi commitment nahi.</p>
  <div class="cta-btns">
    <a href="https://wa.me/916392026107" class="btn-wa">💬 WhatsApp Karein</a>
    <a href="tel:+916392026107" class="btn-call">📞 6392026107</a>
  </div>
</div>

<footer class="footer">
  <p>© 2026 High Tech Pest Control · Mohd Kaleem · Lucknow &nbsp;|&nbsp; <a href="/">Home</a> &nbsp;|&nbsp; <a href="/blog/">Blog</a></p>
</footer>
<a href="https://wa.me/916392026107" class="wa-float" aria-label="WhatsApp">💬</a>
</body>
</html>
