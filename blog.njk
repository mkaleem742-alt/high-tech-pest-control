<!DOCTYPE html>
<html lang="hi-IN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog | Pest Control Tips & Guides | High Tech Pest Control Lucknow</title>
  <meta name="description" content="Pest control, deemak, cockroach aur termite ke baare mein helpful tips aur guides — High Tech Pest Control Lucknow ke experts se. Hindi mein padhein.">
  <meta name="keywords" content="pest control blog lucknow, deemak tips, termite guide hindi, pest control tips">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://hightechpestcontrol.co.in/blog/">
  <meta name="theme-color" content="#0F2E1A">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Noto+Sans+Devanagari:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root{--green-900:#0F2E1A;--green-800:#1A4428;--green-600:#2D7044;--green-100:#E8F5ED;--green-50:#F2FAF5;--saffron:#E8820C;--ivory:#FAFAF7;--cream:#F5F3EE;--text-main:#2A2A27;--text-muted:#6B6860;--font-display:'Playfair Display',Georgia,serif;--font-body:'DM Sans','Noto Sans Devanagari',sans-serif;--shadow-card:0 2px 16px rgba(15,46,26,.08);--shadow-lift:0 8px 32px rgba(15,46,26,.14)}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--font-body);background:var(--ivory);color:var(--text-main);-webkit-font-smoothing:antialiased}
    .nav{background:var(--green-900);padding:14px 20px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:100}
    .nav a{color:rgba(255,255,255,.8);text-decoration:none;font-size:.9rem}
    .nav-logo{font-family:var(--font-display);color:#fff;font-weight:800;font-size:1.1rem}
    .nav-logo span{color:var(--saffron)}
    .blog-hero{background:linear-gradient(135deg,var(--green-900),var(--green-600));padding:56px 20px;text-align:center}
    .blog-hero h1{font-family:var(--font-display);color:#fff;font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:12px}
    .blog-hero p{color:rgba(255,255,255,.8);max-width:560px;margin:0 auto}
    .container{max-width:1100px;margin:0 auto;padding:48px 20px 64px}
    .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
    .blog-card{background:#fff;border-radius:20px;border:1px solid rgba(15,46,26,.08);overflow:hidden;transition:transform .25s,box-shadow .25s;text-decoration:none;color:inherit;display:block}
    .blog-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lift)}
    .blog-img{height:170px;display:flex;align-items:center;justify-content:center;font-size:3rem;background:linear-gradient(135deg,var(--green-100),var(--green-50));overflow:hidden}
    .blog-img img{width:100%;height:100%;object-fit:cover}
    .blog-body{padding:20px}
    .blog-tag{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--saffron);margin-bottom:8px}
    .blog-card h2{font-family:var(--font-display);font-size:1.1rem;color:var(--green-900);margin-bottom:8px}
    .blog-card p{font-size:.87rem;color:var(--text-muted)}
    .blog-date{font-size:.78rem;color:var(--text-muted);margin-top:12px}
    .empty{text-align:center;padding:60px 20px;color:var(--text-muted)}
    .footer{background:var(--green-900);color:rgba(255,255,255,.6);text-align:center;padding:24px;font-size:.85rem}
    .footer a{color:var(--saffron);text-decoration:none}
    .wa-float{position:fixed;bottom:24px;right:24px;background:#25D366;color:#fff;width:58px;height:58px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.5);z-index:999}
    @media(max-width:900px){.blog-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:600px){.blog-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">High<span>Tech</span> Pest Control</a>
  <a href="tel:+916392026107">📞 6392026107</a>
</nav>

<div class="blog-hero">
  <h1>Pest Control Blog & Guides</h1>
  <p>Deemak, cockroach, khatmal aur keedo ke baare mein helpful jankari — Hindi mein, Lucknow ke experts se.</p>
</div>

<div class="container">
  {% if collections.posts.length == 0 %}
    <div class="empty">
      <div style="font-size:3rem;margin-bottom:16px">📝</div>
      <h2 style="font-family:var(--font-display);color:var(--green-900)">Jaldi hi naye posts aayenge!</h2>
    </div>
  {% else %}
    <div class="blog-grid">
      {%- for post in collections.posts | reverse -%}
        <a href="{{ post.url }}" class="blog-card">
          <div class="blog-img">
            {% if post.data.thumbnail %}<img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}">{% else %}🪲{% endif %}
          </div>
          <div class="blog-body">
            <div class="blog-tag">{{ post.data.category }}</div>
            <h2>{{ post.data.title }}</h2>
            {% if post.data.description %}<p>{{ post.data.description | truncate(100) }}</p>{% endif %}
            <div class="blog-date">📅 {{ post.data.date | readableDate }}</div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {% endif %}
</div>

<footer class="footer">
  <p>© 2026 High Tech Pest Control · Mohd Kaleem · Lucknow &nbsp;|&nbsp; <a href="/">Home</a></p>
</footer>
<a href="https://wa.me/916392026107" class="wa-float" aria-label="WhatsApp">💬</a>
</body>
</html>
